---
import Layout from '../layouts/Layout.astro';
import { getSongs } from '../lib/song-loader';
import { normalizeLanguage } from '../lib/language';

const songs = getSongs().sort((a, b) => a.title.localeCompare(b.title, 'zh-Hans-CN'));
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<Layout title="tangkk 的个人和弦谱库" description="tangkk 的个人和弦谱库">
  <header class="home-hero">
    <div class="home-hero-copy">
      <p class="home-eyebrow">tangkk.github.io/chord-sheet-site</p>
      <h1 class="site-title home-title">Chord Sheets</h1>
      <p class="home-subtitle">一个自己长期维护的和弦谱小站。先求干净、耐看、拿起来就能弹。</p>
    </div>
  </header>

  <section class="home-section">
    <div class="home-section-head">
      <h2 class="home-section-title">Songs</h2>
      <p class="home-section-meta">共 {songs.length} 首</p>
    </div>

    <section class="song-flat-list card home-song-list-card">
      {songs.map((song) => {
        const languageLabel = normalizeLanguage(song.language);
        return (
          <article class="song-flat-row">
            <a class="song-flat-title" href={`${baseUrl}songs/${song.slug}/`}>{song.title}</a>
            <span class="song-flat-sep">·</span>
            <span class="song-flat-meta">原调 {song.originalKey}</span>
            {languageLabel && <span class="song-flat-sep">·</span>}
            {languageLabel && <span class="song-flat-meta">{languageLabel}</span>}
            <span class="song-flat-sep">·</span>
            <span class="song-flat-meta">流行</span>
            <span class="song-flat-sep">·</span>
            <span class="song-flat-meta">{song.artist}</span>
          </article>
        );
      })}
    </section>
  </section>
</Layout>
