---
import ChordSheet from '../../components/ChordSheet';
import Layout from '../../layouts/Layout.astro';
import { getSongBySlug, getSongs } from '../../lib/song-loader';

export async function getStaticPaths() {
  return getSongs().map((song) => ({
    params: { slug: song.slug },
  }));
}

const slugParam = Astro.params.slug;
const slug = Array.isArray(slugParam) ? slugParam.join('/') : slugParam ?? '';
const song = getSongBySlug(slug);
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

if (!song) {
  throw new Error(`Song not found: ${slug}`);
}
---

<Layout title={`${song.title} · ${song.artist}`} description={`${song.title} 和弦谱`}>
  <a class="back-link" href={baseUrl}>← 返回歌曲列表</a>

  <section class="song-hero">
    <h1 class="song-title">{song.title}</h1>
    <div class="meta-grid">
      <span>原调：{song.originalKey}</span>
      {song.language ? <span>{song.language === 'yue' ? '粤语' : song.language}</span> : null}
      <span>流行</span>
      <span>{song.artist}</span>
    </div>
  </section>

  <ChordSheet client:load text={song.body} originalKey={song.originalKey} capo={song.capo} />
</Layout>
