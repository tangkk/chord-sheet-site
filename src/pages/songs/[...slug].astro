---
import ChordFinderLink from '../../components/SongChordFinderLink';
import ChordSheet from '../../components/ChordSheet';
import Layout from '../../layouts/Layout.astro';
import { normalizeLanguage } from '../../lib/language';
import { getSongBySlug, getSongs } from '../../lib/song-loader';

export async function getStaticPaths() {
  return getSongs().map((song) => ({
    params: { slug: song.slug },
  }));
}

const slugParam = Astro.params.slug;
const slug = Array.isArray(slugParam) ? slugParam.join('/') : slugParam ?? '';
const song = getSongBySlug(slug);
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

if (!song) {
  throw new Error(`Song not found: ${slug}`);
}

const languageLabel = normalizeLanguage(song.language);
---

<Layout title={`${song.title} · ${song.artist}`} description={`${song.title} 和弦谱`}>
  <a class="back-link" href={baseUrl}>← tangkk.github.io/chord-sheet-site</a>

  <section class="song-hero">
    <h1 class="song-title">{song.title}</h1>
    <div class="meta-grid">
      {languageLabel ? <span>{languageLabel}</span> : null}
      <span>流行</span>
      <span>{song.artist}</span>
    </div>
    <div class="hero-link-row align-right-top">
      <ChordFinderLink
        client:load
        hrefBase={`${baseUrl}chords/?from=${encodeURIComponent(`${baseUrl}songs/${song.slug}/`)}&label=${encodeURIComponent(song.title)}`}
        fallbackKey={song.originalKey}
        label="Chord Finder"
      />
    </div>
  </section>

  <ChordSheet client:load text={song.body} originalKey={song.originalKey} sourceKey={song.sourceKey} capo={song.capo} />
</Layout>
