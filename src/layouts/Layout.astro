---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Chord Sheet Site',
  description = '一个给自己长期维护的和弦谱网站',
} = Astro.props;
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const faviconHref = `${baseUrl}favicon.ico?v=20260405-1`;
---

<!doctype html>
<html lang="zh-Hans">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href={faviconHref} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-shell">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --dense-chord-len: 6;
    --bg: #ffffff;
    --bg-soft: #fafafa;
    --panel: #fcfcfc;
    --panel-border: #e7e7e7;
    --text: #111111;
    --muted: #6b7280;
    --accent: #111111;
    --accent-soft: #f3f4f6;
    --chord: #222222;
    --shadow: 0 8px 24px rgba(17, 17, 17, 0.04);
    --font-latin: 'Avenir Next', Avenir, 'SF Pro Text', 'SF Pro Display', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    --font-cjk: 'PingFang SC', 'Hiragino Sans GB', 'Noto Sans CJK SC', 'Source Han Sans SC', 'Microsoft YaHei', sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-latin), var(--font-cjk);
  }

  a {
    color: var(--accent);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  .page-shell {
    width: min(860px, calc(100% - 24px));
    margin: 0 auto;
    padding: 24px 0 48px;
  }

  .site-header {
    margin-bottom: 18px;
  }

  .top-nav {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 14px;
    margin-bottom: 14px;
    font-size: 0.9rem;
    color: var(--muted);
  }

  .top-nav a {
    color: var(--muted);
  }

  .top-nav a:hover {
    color: var(--text);
    text-decoration: none;
  }

  .hero-link-row {
    margin-top: 10px;
  }

  .hero-link-row.align-right-top {
    margin-top: 0;
    margin-left: auto;
    align-self: flex-start;
  }

  .hero-link {
    display: inline-flex;
    align-items: center;
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 500;
  }

  .hero-link:hover {
    color: var(--text);
    text-decoration: none;
  }

  .site-title {
    margin: 0 0 8px;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
  }

  .home-hero {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--panel-border);
    margin-bottom: 24px;
  }

  .home-hero-copy {
    min-width: 0;
    flex: 1 1 auto;
  }

  .home-hero-action {
    flex: 0 0 auto;
  }

  .home-avatar {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    flex: 0 0 auto;
    display: block;
    object-fit: cover;
  }

  .home-eyebrow {
    margin: 0 0 8px;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .home-subtitle {
    margin: 10px 0 0;
    max-width: 36rem;
    color: var(--muted);
    font-size: 0.96rem;
    line-height: 1.75;
  }

  .home-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .home-section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }

  .home-section-title {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.35;
  }

  .home-section-meta {
    margin: 0;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .site-subtitle,
  .muted {
    color: var(--muted);
  }

  .card {
    background: var(--panel);
    border: 1px solid var(--panel-border);
    border-radius: 14px;
    box-shadow: var(--shadow);
  }

  .song-list {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .song-card {
    padding: 20px;
  }

  .song-card h2,
  .song-card h3 {
    margin: 0 0 10px;
  }

  .home-title {
    margin-bottom: 0;
    font-size: clamp(1.8rem, 3.4vw, 2.4rem);
  }

  .home-song-list-card {
    padding: 8px 16px;
  }

  .song-flat-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .song-flat-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 4px 8px;
    padding: 14px 2px;
    border-bottom: 1px solid var(--panel-border);
    font-size: 0.97rem;
    line-height: 1.45;
  }

  .song-flat-row:last-child {
    border-bottom: 0;
  }

  .song-flat-title {
    color: var(--text);
    font-weight: 600;
  }

  .song-flat-title:hover {
    text-decoration: none;
  }

  .song-flat-meta {
    color: var(--muted);
  }

  .song-flat-sep {
    color: #b6b6b6;
  }

  .tag-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 12px;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    padding: 0;
    border-radius: 0;
    background: transparent;
    color: #6b7f95;
    font-size: 0.88rem;
  }

  .meta-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 12px;
    margin: 4px 0 0;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .song-hero .meta-grid,
  .home-hero-copy {
    min-width: 0;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 14px;
    color: var(--muted);
    font-size: 0.94rem;
  }

  .back-link:hover {
    color: var(--text);
  }

  .song-hero {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 8px 12px;
    padding: 0 0 16px;
    margin-bottom: 18px;
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--panel-border);
    box-shadow: none;
  }

  .song-title {
    margin: 0 0 6px;
    font-size: clamp(1.8rem, 3.4vw, 2.4rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    width: 100%;
  }

  .chord-sheet-card {
    padding: 0;
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  .toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 12px;
    align-items: center;
    justify-content: space-between;
    padding: 0 0 12px;
    margin: 0 0 14px;
    border-bottom: 1px solid var(--panel-border);
  }

  .toolbar-readout {
    gap: 8px;
    color: var(--text);
  }

  .toolbar-key-value {
    font-size: 0.96rem;
    font-weight: 700;
    line-height: 1;
  }

  .toolbar-key-origin {
    font-size: 0.76rem;
    color: var(--muted);
    line-height: 1;
  }

  .toolbar-buttons {
    gap: 6px;
  }

  .toolbar button {
    min-width: 34px;
    min-height: 30px;
    padding: 0 10px;
    border-radius: 10px;
    font-size: 0.92rem;
    font-weight: 700;
    background: #fff;
  }

  .toolbar-group {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .label {
    color: var(--muted);
    font-size: 0.88rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  button,
  select {
    background: #ffffff;
    color: var(--text);
    border: 1px solid var(--panel-border);
    border-radius: 8px;
    padding: 6px 10px;
    font: inherit;
    line-height: 1.2;
  }

  button:hover,
  select:hover {
    border-color: #b9b9b9;
    cursor: pointer;
  }

  .sheet {
    display: flex;
    flex-direction: column;
    gap: 4px;
    overflow: visible;
  }

  .line {
    display: flex;
    flex-wrap: nowrap;
    align-items: flex-start;
    column-gap: 0.18rem;
    row-gap: 2px;
    overflow: visible;
  }

  .line.blank {
    min-height: 4px;
  }

  .section-line {
    margin: 10px 0 4px;
    color: var(--muted);
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: none;
    line-height: 1.2;
  }

  .section-line-inner {
    display: inline-block;
    padding: 1px 0;
    font-style: italic;
  }

  .alt-line {
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.25;
    padding-left: 2px;
    font-style: italic;
    margin-top: -3px;
  }

  .chords-only-line {
    display: flex;
    flex-wrap: wrap;
    gap: 2px 8px;
    align-items: center;
    padding: 0;
    margin: 2px 0;
  }

  .section-line + .chords-only-line {
    margin-top: 4px;
  }

  .chords-only-line + .chords-only-line {
    margin-top: 0;
    margin-bottom: 0;
  }

  .chords-only-line + .line,
  .chords-only-line + .alt-line,
  .chords-only-line + .section-line {
    margin-top: 6px;
  }

  .chords-only-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.2rem;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--chord);
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0;
    font-family: var(--font-latin);
  }

  .chords-only-bar {
    color: #9aa8b5;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .segment {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    white-space: pre;
    min-width: max-content;
  }

  .segment.dense-short {
    padding-right: 0.3rem;
  }

  .chord {
    min-height: .95em;
    margin-bottom: 0;
    color: var(--chord);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1;
    font-family: var(--font-latin);
  }

  .lyric {
    display: inline-block;
    min-width: 100%;
    font-size: 0.96rem;
    line-height: 1.18;
    font-family: var(--font-latin), var(--font-cjk);
  }

  .lyric.spacer {
    min-width: 1.35rem;
  }

  .chord-finder-card {
    padding: 18px;
  }

  .chord-finder-head {
    margin-bottom: 14px;
  }

  .chord-finder-title {
    margin-bottom: 6px;
  }

  .chord-finder-input-row {
    margin-bottom: 12px;
  }

  .chord-finder-input {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid var(--panel-border);
    border-radius: 12px;
    font: inherit;
    font-size: 1rem;
    background: #fff;
    color: var(--text);
  }

  .chord-finder-suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .chord-pill {
    min-height: 32px;
    padding: 0 12px;
    border-radius: 999px;
    background: var(--accent-soft);
    border: 1px solid var(--panel-border);
    font-size: 0.88rem;
    font-weight: 600;
  }

  .chord-finder-results {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .chord-result-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 14px 0;
    border-top: 1px solid var(--panel-border);
  }

  .chord-result-row:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .chord-result-main {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  .chord-result-copy {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .chord-result-name {
    font-size: 1rem;
    font-weight: 700;
  }

  .chord-result-fret {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.94rem;
    color: var(--text);
  }

  .chord-result-notes {
    color: var(--muted);
    font-size: 0.88rem;
    white-space: nowrap;
  }

  .chord-diagram {
    width: 96px;
    flex: 0 0 auto;
  }

  .chord-diagram-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 6px;
  }

  .chord-diagram-name {
    font-size: 0.86rem;
    font-weight: 700;
  }

  .chord-diagram-base-fret {
    font-size: 0.72rem;
    color: var(--muted);
  }

  .chord-diagram-svg {
    display: block;
    width: 84px;
    height: 110px;
    overflow: visible;
  }

  .chord-diagram-head-text {
    fill: var(--muted);
    font-size: 11px;
    font-family: var(--font-latin);
  }

  .chord-diagram-string {
    stroke: #c2c9d1;
    stroke-width: 1.2;
  }

  .chord-diagram-fret {
    stroke: #cfd5dc;
    stroke-width: 1.2;
  }

  .chord-diagram-nut {
    stroke: #7a8088;
    stroke-width: 3;
  }

  .chord-diagram-dot {
    fill: var(--text);
  }

  .chord-diagram-barre {
    stroke: var(--text);
    stroke-width: 9.5;
    stroke-linecap: round;
  }

  @media (max-width: 720px) {
    .page-shell {
      width: min(100% - 14px, 1180px);
      padding-top: 10px;
      padding-bottom: 24px;
      padding-right: 0;
    }

    .home-hero {
      align-items: flex-start;
      gap: 14px;
      margin-bottom: 18px;
      padding-bottom: 16px;
    }

    .home-avatar {
      width: 72px;
      height: 72px;
    }

    .chord-sheet-card,
    .song-hero,
    .song-card {
      padding: 0;
    }

    .song-flat-row {
      font-size: 0.92rem;
      gap: 3px 6px;
    }

    .toolbar {
      align-items: center;
      justify-content: space-between;
      gap: 8px 10px;
    }

    .toolbar-key-value {
      font-size: 0.9rem;
    }

    .toolbar-key-origin {
      font-size: 0.72rem;
    }

    .toolbar button {
      min-width: 32px;
      min-height: 28px;
      font-size: 0.88rem;
    }

    .lyric {
      font-size: 0.92rem;
      line-height: 1.14;
    }

    .chord {
      font-size: 0.78rem;
    }

    .sheet {
      gap: 3px;
    }

    .mobile-reading-line {
      flex-wrap: wrap;
      row-gap: 6px;
      overflow-x: visible;
    }

    .mobile-reading-line .segment {
      min-width: 0;
      margin-right: 0.14rem;
    }

    .mobile-reading-line .lyric {
      min-width: auto;
      white-space: pre-wrap;
    }
  }
</style>
